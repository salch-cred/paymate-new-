# Optional: enables AI-structured invoice drafting via OpenAI.
# A deterministic no-key parser is used automatically when this is blank.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Metis Sepolia (chain id 59902) RPC endpoint.
RPC_METIS_TESTNET=https://sepolia.metisdevops.link

# Settlement token PayMate accepts as "USDC" on Metis Sepolia.
# No official Circle USDC exists on this testnet yet — deploy a test ERC-20
# (6 decimals) or point this at whichever test token you're settling with.
USDC_TOKEN=0xYOUR_METIS_SEPOLIA_USDC_ADDRESS
USDC_DECIMALS=6

# Deployed PayMateReputation contract address (see ../contracts).
REPUTATION_CONTRACT=0xYOUR_DEPLOYED_REPUTATION_CONTRACT

# Wallet authorized to call recordJob on the reputation contract
# (must be the same account that deployed PayMateReputation, its `issuer`).
PRIVATE_KEY=0xISSUER_PRIVATE_KEY

# Optional: override the SQLite file location (defaults to web/paymate.db).
PAYMATE_DB_PATH=
