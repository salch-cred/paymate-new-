# GOAT Testnet3 (chain id 48816) RPC endpoint.
RPC_GOAT_TESTNET=https://rpc.testnet3.goat.network

# Deployer / issuer key used by scripts/deploy.ts (PayMateReputation owner).
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# ERC-8004 identity registry address (see scripts/register-erc8004.ts).
# Mainnet: 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432 — no known Testnet3
# deployment yet, confirm with the GOAT team before setting this on testnet.
REGISTRY_CONTRACT=
# Human-readable agent name to register.
AGENT_NAME=
# Publicly reachable JSON metadata URL describing this agent (name,
# description, url, wallet) — e.g. a GitHub Gist raw link.
AGENT_URI=
